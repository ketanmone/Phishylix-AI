{
  "manifest_version": 3,
  "name": "Phishylix AI",
  "version": "1.0",
  "description": "AI-driven phishing defence for detecting synthetic phishing webpages.",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Phishylix AI"
  }
}